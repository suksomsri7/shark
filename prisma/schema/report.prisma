// Report builder v1 (WO-0055) — รายงานที่บันทึกไว้
model ReportDef {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  configJson Json     @default("{}") // { dataset, filters, groupBy, metric }
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
}
