// SHARK — CORE schema (Stage A1)
// ⚠️ FROZEN หลัง Stage A — ห้าม session โมดูลแก้ไฟล์นี้ (ดู docs/WORKPLAN_PARALLEL.md §3)
// อ้างอิง: BLUEPRINT.md · BLUEPRINT_BUSINESS_UNITS.md · qc/RESOLUTIONS.md

generator client {
  provider = "prisma-client-js"
}

// Prisma 7: connection URL ย้ายไป prisma.config.ts
// - CLI (migrate/introspect) ใช้ DIRECT_URL จาก config
// - runtime client ใช้ DATABASE_URL (pooled) ผ่าน datasourceUrl ใน src/lib/core/db.ts
datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// TENANT (บัญชีร้าน = 1 องค์กร)
// ─────────────────────────────────────────────────────────────
enum TenantStatus {
  PENDING // สมัครแล้วยังไม่ยืนยัน/รออนุมัติ
  ACTIVE
  SUSPENDED // ระงับ: login ไม่ได้ + storefront 410
  CLOSED
  PENDING_DELETE // PDPA soft delete 30 วัน
}

enum DomainStatus {
  NONE
  PENDING_DNS
  VERIFYING
  ACTIVE
  FAILED
}

enum Plan {
  FREE
}

model Tenant {
  id             String       @id @default(cuid())
  name           String
  slug           String       @unique // shark.in.th/s/{slug}
  status         TenantStatus @default(ACTIVE)
  plan           Plan         @default(FREE)
  enabledModules Json         @default("[]") // ["BOOKING","POS",...] เปิด/ปิดรายโมดูล
  limits         Json         @default("{}") // { maxUnits: 5, ... }
  customDomain   String?      @unique
  domainStatus   DomainStatus @default(NONE)
  deleteRequestedAt DateTime? // PDPA (WO-0042): ขอลบร้าน — purge จริงหลัง 30 วัน (cron)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  units       BusinessUnit[]
  memberships Membership[]
  auditLogs   AuditLog[]

  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// BUSINESS UNIT (หน่วยธุรกิจ: โรงแรม A, ร้านอาหาร 1..3)
// ─────────────────────────────────────────────────────────────
enum UnitType {
  HOTEL
  RESTAURANT
  BOOKING
  QUEUE
  TICKET
  SHOP // ร้านค้าทั่วไปที่ใช้ POS เดี่ยว
}

enum UnitStatus {
  ACTIVE
  PAUSED // ซ่อนจาก storefront, honor ธุรกรรมเดิม
  ARCHIVED // read-only
}

model BusinessUnit {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      UnitType
  name      String
  slug      String // immutable หลังสร้าง
  status    UnitStatus @default(ACTIVE)
  settings  Json       @default("{}") // { timezone, openHours, account:{vatMode,vatRate,taxId}, ... }
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, type])
}

// ─────────────────────────────────────────────────────────────
// IDENTITY: User (ตัวตนเดียว ใช้ได้ทุกบทบาท/หลาย tenant)
// ─────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  sessions    Session[]
}

enum Role {
  OWNER // ["*"] ทุกหน่วยทุกโมดูลเสมอ
  MANAGER // คุมบางหน่วยเต็มสิทธิ์
  STAFF // เฉพาะหน่วย + เฉพาะโมดูล
}

// ผูก User เข้ากับ Tenant + สิทธิ์ (RBAC 4 มิติ: tenant→unit→module→action)
model Membership {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role        Role
  unitAccess  Json     @default("[]") // ["*"] | ["unitId1","unitId2"]
  permissions Json     @default("{}") // สิทธิ์รายโมดูล/action (STAFF); { "pos.sale.void": true, "_maxDiscountBp": 500 }
  invitedAt   DateTime @default(now())
  acceptedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────
// AUTH (passwordless email: magic link + OTP) — token เก็บ hash
// ─────────────────────────────────────────────────────────────
enum AuthPurpose {
  MAGIC_LINK
  OTP
}

model AuthToken {
  id         String      @id @default(cuid())
  email      String
  purpose    AuthPurpose
  tokenHash  String // hash เท่านั้น ไม่เก็บ plaintext
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int         @default(0) // OTP: นับผิดเพื่อ lockout
  ip         String?
  createdAt  DateTime    @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique // __Host- cookie hash + rotation
  userAgent  String?
  ip         String?
  expiresAt  DateTime // absolute
  idleExpiresAt DateTime // idle timeout (rotation)
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────
// PLATFORM (backoffice — แยก session namespace จากร้านโดยสิ้นเชิง)
// ─────────────────────────────────────────────────────────────
enum PlatformRole {
  SUPER_ADMIN
  SUPPORT
  FINANCE
}

model PlatformUser {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  role          PlatformRole
  totpSecret    String? // 2FA บังคับ (field เผื่อ)
  totpEnabledAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOG (กลาง — action ที่แตะเงิน/แต้ม/สิทธิ์/ตั้งค่า)
// ─────────────────────────────────────────────────────────────
enum ActorType {
  USER
  PLATFORM_USER
  SYSTEM
}

model AuditLog {
  id         String    @id @default(cuid())
  tenantId   String?
  tenant     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  unitId     String?
  actorType  ActorType
  actorId    String?
  onBehalfOf String? // impersonation: PlatformUser.id ที่กระทำแทน
  action     String // เช่น "membership.role.changed"
  targetType String?
  targetId   String?
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([action])
}
