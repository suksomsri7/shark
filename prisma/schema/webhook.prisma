// Webhooks ขาออก (WO-0062) — สมัคร URL ต่อ event + ลายเซ็น HMAC + retry
model WebhookEndpoint {
  id         String    @id @default(cuid())
  tenantId   String
  url        String
  secret     String // ใช้เซ็น X-Shark-Signature = hex(hmacSHA256(secret, body))
  eventsJson Json      @default("[]") // ["pos.sale.paid", ...] ว่าง = ทุก event
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  deliveries WebhookDelivery[]

  @@index([tenantId, active])
}

enum WebhookDeliveryStatus {
  OK
  FAILED
}

model WebhookDelivery {
  id          String                @id @default(cuid())
  tenantId    String
  endpointId  String
  endpoint    WebhookEndpoint       @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  eventType   String
  payloadJson Json                  @default("{}")
  status      WebhookDeliveryStatus
  attempts    Int                   @default(1)
  lastError   String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([tenantId, status])
  @@index([endpointId, createdAt])
}
