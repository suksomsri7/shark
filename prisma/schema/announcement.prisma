// ประกาศระบบ (WO-0031 — BACKOFFICE.md Phase 1 ตัวสุดท้าย)
// แพลตฟอร์มประกาศ → ทุกร้านเห็น banner จนกด "รับทราบ" (dismiss ต่อร้าน)
model PlatformAnnouncement {
  id                      String    @id @default(cuid())
  title                   String
  body                    String
  publishedAt             DateTime? // null = ฉบับร่าง
  createdByPlatformUserId String
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([publishedAt])
}

model AnnouncementDismiss {
  id             String   @id @default(cuid())
  tenantId       String
  announcementId String
  createdAt      DateTime @default(now())

  @@unique([tenantId, announcementId])
}
