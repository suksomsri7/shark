// Inventory (ระบบ 18) — สต็อกกลาง + movement ledger (contract C-1)
// InvItem = "ของจริงมีเท่าไหร่" · movement append-only ทุกแถวอ้าง refType/refId
// นโยบาย: ตัดสต็อกยอมติดลบ (default) + ธง needsReview — ร้านจริงขายไปก่อนค่อยเคลียร์
enum InvMovementType {
  IN
  OUT
  ADJUST
  TRANSFER
}

model InvItem {
  id             String   @id @default(cuid())
  tenantId       String
  systemId       String
  sku            String
  barcode        String?
  name           String
  unitLabel      String   @default("ชิ้น")
  category       String?
  costSatang     Int      @default(0) // ต้นทุนถัวเฉลี่ย
  onHand         Int      @default(0) // cache — sync จาก movement (source of truth = ledger)
  reorderPoint   Int      @default(0)
  accountProductId String? // sync กับ AccountProduct (มูลค่า/เอกสาร) — ไม่ซ้ำ
  archivedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  movements InvMovement[]
  @@unique([systemId, sku])
  @@index([systemId, onHand])
  @@index([tenantId])
}

// Multi-warehouse (WO-0037) — Location ต่อ system · onHand ต่อ location (cache)
// invariant: sum(InvLocationStock.onHand ของ item) == InvItem.onHand (lazy migration: แถว default ถูก seed จาก onHand เดิมครั้งแรกที่ item ถูกแตะ)
model InvLocation {
  id         String    @id @default(cuid())
  tenantId   String
  systemId   String
  name       String
  isDefault  Boolean   @default(false)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([systemId, name])
  @@index([tenantId])
}

model InvLocationStock {
  id         String @id @default(cuid())
  tenantId   String
  systemId   String
  itemId     String
  locationId String
  onHand     Int    @default(0)

  @@unique([itemId, locationId])
  @@index([tenantId])
  @@index([systemId, locationId])
}

// Lot/Expiry (WO-0038) — lot ต่อ item (orthogonal กับ location v1: lot ไม่แยกต่อคลัง)
// invariant เบา: lot.onHand เดินตาม movement ที่ระบุ lotCode เท่านั้น (ไม่ระบุ = ไม่แตะ lot)
model InvLot {
  id         String    @id @default(cuid())
  tenantId   String
  systemId   String
  itemId     String
  lotCode    String
  expiryDate DateTime? @db.Date
  onHand     Int       @default(0)
  createdAt  DateTime  @default(now())

  @@unique([itemId, lotCode])
  @@index([tenantId])
  @@index([systemId, expiryDate])
}

model InvMovement {
  id             String          @id @default(cuid())
  tenantId       String
  systemId       String
  itemId         String
  item           InvItem         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type           InvMovementType
  locationId     String?         // null = แถว legacy ก่อนยุค multi-warehouse (นับเป็นคลัง default)
  lotCode        String?         // WO-0038: movement ที่ระบุ lot
  qtyDelta       Int             // + รับเข้า / - ตัดออก
  balanceAfter   Int             // onHand หลังรายการนี้ (audit trail)
  costSatang     Int             @default(0)
  sourceModule   String?         // POS/RESTAURANT/ACCOUNT/manual
  refType        String?
  refId          String?
  idempotencyKey String
  note           String?
  needsReview    Boolean         @default(false) // ตัดจนติดลบ = ตั้งธง
  createdAt      DateTime        @default(now())
  @@unique([tenantId, idempotencyKey])
  @@index([systemId, itemId, createdAt])
}
