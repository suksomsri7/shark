// AI Layer (Phase 1 — docs/AI_LAYER.md) — บทสนทนาผู้ช่วย AI + cost guard ต่อ tenant
// tenant-scoped (ผู้ช่วยผูกกิจการ ไม่ผูก system) · ข้อความ append-only
enum AiRole {
  USER
  ASSISTANT
}

model AiConversation {
  id        String   @id @default(cuid())
  tenantId  String
  title     String   @default("") // บรรทัดแรกของข้อความแรก (ตัด 60 ตัว)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AiMessage[]

  @@index([tenantId, updatedAt])
}

model AiMessage {
  id             String         @id @default(cuid())
  tenantId       String
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           AiRole
  content        String
  tokensIn       Int            @default(0) // นับเฉพาะแถว ASSISTANT (ของ request นั้น)
  tokensOut      Int            @default(0)
  createdAt      DateTime       @default(now())

  @@index([tenantId, conversationId, createdAt])
}

// Phase 3.5 — ข้อเสนอการกระทำของ AI (proposal → user ยืนยัน → execute)
// กฎเหล็ก: execute อ่าน payload จากแถวนี้เท่านั้น (ห้ามเชื่อ client) + assertCan สิทธิ์คนกด ณ ตอน execute
enum AiProposalStatus {
  PENDING
  EXECUTED
  REJECTED
  FAILED
  EXPIRED
}

model AiProposal {
  id             String           @id @default(cuid())
  tenantId       String
  conversationId String
  kind           String // "inventory_receive" | "hr_decide_leave" | ...
  risk           String           @default("NORMAL") // NORMAL | DESTRUCTIVE (ลบ/void/ยกเลิก — ต้องยืนยัน 2 ชั้น)
  summary        String // ไทย — UI ใช้แสดงการ์ดยืนยัน "จะทำอะไร"
  payload        Json // พารามิเตอร์ (server-side เท่านั้น)
  status         AiProposalStatus @default(PENDING)
  resultNote     String? // ผลหลังทำ / เหตุผลที่ไม่สำเร็จ (ไทย)
  expiresAt      DateTime // TTL 24 ชม.
  executedAt     DateTime?
  createdAt      DateTime         @default(now())

  @@index([tenantId, conversationId, status, createdAt])
}

// เพดานการใช้ต่อ tenant ต่อวัน (วัน = Asia/Bangkok) — upsert เพิ่มยอด
model AiUsage {
  id        String @id @default(cuid())
  tenantId  String
  day       String // "YYYY-MM-DD" BKK
  requests  Int    @default(0)
  tokensIn  Int    @default(0)
  tokensOut Int    @default(0)

  @@unique([tenantId, day])
}

// AI training samples (distillation dataset — เก็บไว้เทรนโมเดลเล็ก self-host อนาคต)
// ⚠️ PDPA: anonymize ก่อนเก็บ (แทนชื่อ/เบอร์/อีเมล ด้วย placeholder) · เก็บเมื่อ SHARK_AI_COLLECT=1 เท่านั้น
// ของมีค่า = โครง tool-calling (คำสั่ง → เครื่องมือที่เลือก) ไม่ใช่ข้อมูลลูกค้า
model AiTrainingSample {
  id           String   @id @default(cuid())
  tenantId     String
  userText     String // anonymized
  toolCallsJson Json    @default("[]") // [{name, args(anonymized)}]
  replyText    String // anonymized
  model        String // haiku | sonnet — ครูที่ผลิต sample
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
}

// AI Memory (agentic-1) — ความจำถาวรต่อร้าน (AI จดจากบทสนทนา → ฉีดเข้า system prompt)
model AiMemory {
  id        String   @id @default(cuid())
  tenantId  String
  content   String // ข้อเท็จจริงสั้น ๆ ("ร้านหยุดวันจันทร์")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, updatedAt])
}

// AI Plan (agentic-2 — L2) — แผนหลายขั้น: เสนอทั้งชุด ยืนยันครั้งเดียว ทำต่อเนื่อง รายงานทีละขั้น
model AiPlan {
  id             String   @id @default(cuid())
  tenantId       String
  conversationId String
  title          String // ไทย — "ปิดยอดวันนี้"
  status         String   @default("PENDING") // PENDING|RUNNING|DONE|FAILED|REJECTED|EXPIRED
  hasDestructive Boolean  @default(false) // มี step ลบ/ยกเลิก → ยืนยัน 2 ชั้นระดับแผน
  stepsJson      Json     @default("[]") // [{kind, summary, payload, status:PENDING|DONE|FAILED, note?}]
  expiresAt      DateTime
  executedAt     DateTime?
  createdAt      DateTime @default(now())

  @@index([tenantId, conversationId, status])
}

// AI Scheduled Task (agentic-3) — งานประจำที่ AI ทำเองตามเวลา (read/summary → AppNotification)
model AiScheduledTask {
  id          String    @id @default(cuid())
  tenantId    String
  instruction String // "สรุปยอดขายวันนี้ + สต็อกใกล้หมด"
  hourBkk     Int // 0-23 ชั่วโมงตามเวลาไทยที่ให้รัน
  active      Boolean   @default(true)
  lastRunDay  String? // "YYYY-MM-DD" (BKK) กันรันซ้ำในวันเดียวกัน
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId, active])
  @@index([active, hourBkk])
}

// AI Feedback (self-improving item 3) — ปุ่ม 👍👎 ใต้คำตอบ AI → ข้อมูลติดป้ายสำหรับวัดคุณภาพ+เทรน
model AiFeedback {
  id             String   @id @default(cuid())
  tenantId       String
  conversationId String?
  userText       String // คำถามของ user (anonymized)
  replyText      String // คำตอบ AI (anonymized)
  rating         String // UP | DOWN
  note           String? // เหตุผลถ้ากด 👎
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([rating, createdAt])
}

// AI Prompt Tweak (self-improving item 4) — ข้อความปรับปรุงระบบ AI ระดับแพลตฟอร์ม (ทุกร้าน)
// วงจร: วิเคราะห์เคสพลาด → เสนอ (PENDING) → แอดมิน backoffice อนุมัติ (APPROVED=ใช้จริง) / ปฏิเสธ
model AiPromptTweak {
  id             String   @id @default(cuid())
  content        String // คำสั่งเสริมที่จะแทรกเข้า system prompt
  rationale      String // เหตุผล (สรุปจากเคสที่พลาด)
  status         String   @default("PENDING") // PENDING | APPROVED | REJECTED
  decidedById    String? // PlatformUser.id
  decidedAt      DateTime?
  createdAt      DateTime @default(now())

  @@index([status, createdAt])
}
