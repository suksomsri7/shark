// Ticket (ตั๋ว / อีเวนต์) — scope=unit (tenantId+unitId ทุกตาราง)
// MVP: อีเวนต์ + ประเภทตั๋ว(quota) + ออเดอร์ขาย/จอง manual + ตั๋วรายใบ(code) + เช็คอิน
// ชื่อ model นำหน้า Ticket* กันชน QueueTicket (โมดูล Q)
// เลื่อนไป 🔜: ชำระเงินออนไลน์จริง(PaymentIntent), สแกน QR กล้อง, storefront ขายสาธารณะ,
//              seat map, ผูก POS/point earn, หลายรอบ(session), โซน, refund policy
// เงินทั้งหมด Int หน่วยสตางค์ (satang) · เวลา DateTime UTC (แสดงผล Asia/Bangkok)

enum TicketEventStatus {
  DRAFT      // ยังไม่เผยแพร่
  PUBLISHED  // เปิดขาย
  ENDED      // จบงานแล้ว
  CANCELLED  // ยกเลิกงาน
}

enum TicketOrderStatus {
  PENDING    // จอง/รอชำระ (ตัดโควตาไว้แล้ว)
  PAID       // ชำระแล้ว
  CANCELLED  // ยกเลิก (คืนโควตาแล้ว)
}

enum TicketAdmissionStatus {
  VALID       // ตั๋วใช้ได้ ยังไม่เข้างาน
  CHECKED_IN  // เช็คอินแล้ว
  VOID        // ยกเลิก (ออเดอร์ถูกยกเลิก)
}

model TicketEvent {
  id            String            @id @default(cuid())
  tenantId      String
  unitId        String

  name          String
  description   String?
  venue         String?
  coverImageUrl String?
  startAt       DateTime
  endAt         DateTime?
  status        TicketEventStatus @default(DRAFT)

  publishedAt   DateTime?
  archivedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  ticketTypes   TicketType[]
  orders        TicketOrder[]
  admissions    TicketAdmission[]

  @@index([tenantId])
  @@index([unitId, status])
  @@index([unitId, startAt])
}

model TicketType {
  id           String            @id @default(cuid())
  tenantId     String
  unitId       String
  eventId      String
  event        TicketEvent       @relation(fields: [eventId], references: [id])

  name         String            // "บัตรทั่วไป", "VIP"
  description  String?
  priceSatang  Int               @default(0)
  quota        Int               @default(0)   // จำนวนที่ขายได้ทั้งหมด
  sold         Int               @default(0)   // ตัดแล้ว (รวม PENDING + PAID ที่ยังไม่ยกเลิก)
  sortOrder    Int               @default(0)
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  admissions   TicketAdmission[]

  @@index([tenantId])
  @@index([unitId])
  @@index([eventId])
}

model TicketOrder {
  id           String            @id @default(cuid())
  tenantId     String
  unitId       String
  eventId      String
  event        TicketEvent       @relation(fields: [eventId], references: [id])

  orderNo      String            // "TO-250711-0001" running ต่อ unit ต่อวัน
  customerId   String?           // ผูกระบบสมาชิก (optional)
  buyerName    String            // snapshot
  buyerPhone   String?           // snapshot
  status       TicketOrderStatus @default(PENDING)
  totalSatang  Int               @default(0)
  channel      String            @default("STAFF") // STAFF (หน้างาน) | ONLINE
  note         String?

  paidAt       DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  admissions   TicketAdmission[]

  @@unique([unitId, orderNo])
  @@index([tenantId])
  @@index([unitId, status])
  @@index([eventId, status])
  @@index([customerId])
}

model TicketAdmission {
  id            String                @id @default(cuid())
  tenantId      String
  unitId        String
  eventId       String
  event         TicketEvent           @relation(fields: [eventId], references: [id])
  orderId       String
  order         TicketOrder           @relation(fields: [orderId], references: [id])
  ticketTypeId  String
  ticketType    TicketType            @relation(fields: [ticketTypeId], references: [id])

  code          String                // รหัสตั๋ว/QR (opaque, กรอกเช็คอินได้) — unique ต่อ unit
  priceSatang   Int                   @default(0)   // snapshot ราคาต่อใบ
  attendeeName  String?
  status        TicketAdmissionStatus @default(VALID)
  checkedInAt   DateTime?
  checkedInBy   String?               // userId ที่เช็คอิน
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([unitId, code])
  @@index([tenantId])
  @@index([unitId, status])
  @@index([eventId, status])
  @@index([orderId])
  @@index([ticketTypeId])
}
