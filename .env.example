# ── Database (Neon — Singapore ap-southeast-1) ─────────────────
# pooled (-pooler) สำหรับ runtime, direct สำหรับ migrate — ดู docs/INFRA.md §2
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/shark?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/shark?sslmode=require"

# ── App ────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
APP_ENV="development"                 # development | production
SESSION_SECRET="dev-only-change-me-32chars-minimum-secret"

# ── Email ──────────────────────────────────────────────────────
# ส่ง OTP/magic link ผ่าน Resend (verify domain shark.in.th)
RESEND_API_KEY=""
EMAIL_FROM="SHARK <noreply@shark.in.th>"

# ── Object storage (Bunny zone แยก / Vercel Blob) ──────────────
STORAGE_PROVIDER="local"              # local | bunny | vercel-blob
BUNNY_STORAGE_ZONE=""
BUNNY_STORAGE_KEY=""
BUNNY_CDN_HOST=""

# ── Object storage: อัปโหลดโลโก้/ไฟล์แนบขึ้น Bunny (WO-0024) ────
# ต้องครบทั้ง 3 ตัวถึงจะเปิดปุ่มอัปโหลด · ว่าง = ปิดสุภาพ (วาง URL เองยังใช้ได้)
SHARK_BUNNY_ZONE=""                   # ชื่อ Storage Zone บน Bunny (สิงคโปร์ sg)
SHARK_BUNNY_KEY=""                    # Storage Zone Password (ใช้เป็น header AccessKey)
SHARK_BUNNY_CDN=""                    # โฮสต์ CDN สาธารณะ เช่น https://shark.b-cdn.net (ไม่ต้องมี / ท้าย)

# ── Custom Domain: ร้านต่อโดเมนตัวเองเข้าหน้าร้าน (WO-0025) ─────
# ต้องครบทั้ง TOKEN + PROJECT ถึงจะเปิดฟีเจอร์ · ว่าง = ปิดสุภาพ (ปุ่มเชื่อมโดเมนแจ้งยังไม่เปิด)
SHARK_VERCEL_TOKEN=""                 # Vercel Access Token (สิทธิ์จัดการ Domains ของ project)
SHARK_VERCEL_PROJECT=""               # Project ID หรือชื่อ project บน Vercel
SHARK_VERCEL_TEAM=""                  # Team ID (ถ้า project อยู่ใต้ทีม) — เว้นว่างถ้าเป็น personal

# ── Cron ───────────────────────────────────────────────────────
CRON_SECRET="dev-cron-secret"
# ความลับ cron ประจำวัน (/api/cron/tick) — Vercel Cron ส่ง header authorization: Bearer <ค่านี้>
# ว่าง = route ตอบ 401 ทุกครั้ง (ปิดสุภาพ) — ต้องตั้งใน Vercel env ถึงจะเปิดงานกวาดประจำวัน
SHARK_CRON_SECRET="dev-cron-secret"

# AI Layer (docs/AI_LAYER.md)
SHARK_AI_KEY=""            # OpenRouter key ชื่อ "shark" เท่านั้น — ว่าง = ปิดชั้น AI อย่างสุภาพ
SHARK_AI_MODEL="anthropic/claude-haiku-4.5"
# SHARK_AI_MOCK=1          # oracle/dev
