# ── Database (Neon — Singapore ap-southeast-1) ─────────────────
# pooled (-pooler) สำหรับ runtime, direct สำหรับ migrate — ดู docs/INFRA.md §2
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/shark?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/shark?sslmode=require"

# ── App ────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
APP_ENV="development"                 # development | production
SESSION_SECRET="dev-only-change-me-32chars-minimum-secret"

# ── Email ──────────────────────────────────────────────────────
# ส่ง OTP/magic link ผ่าน Resend (verify domain shark.in.th)
RESEND_API_KEY=""
EMAIL_FROM="SHARK <noreply@shark.in.th>"

# ── Object storage (Bunny zone แยก / Vercel Blob) ──────────────
STORAGE_PROVIDER="local"              # local | bunny | vercel-blob
BUNNY_STORAGE_ZONE=""
BUNNY_STORAGE_KEY=""
BUNNY_CDN_HOST=""

# ── Cron ───────────────────────────────────────────────────────
CRON_SECRET="dev-cron-secret"
